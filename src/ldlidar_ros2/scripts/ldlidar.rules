# set the udev rule, make the device port fixed for LDLiDAR on this robot
# Legacy CP210x USB Device
KERNEL=="ttyUSB*", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", MODE:="0666", SYMLINK+="jlink_lidar"
# Current ACM device used by the robot
KERNEL=="ttyACM*", ATTRS{idVendor}=="1366", ATTRS{idProduct}=="0105", MODE:="0666", SYMLINK+="jlink_lidar"
